{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-radar.local/schemas/experience/experience.schema.json",
  "title": "Experience Repository Entity",
  "description": "Repository-only schema for Experience entities derived from registered Patterns and Cases.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experience_id",
    "version",
    "status",
    "title",
    "description",
    "source_patterns",
    "source_cases",
    "health",
    "health_state",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "experience_id": {
      "type": "string",
      "pattern": "^EXP-[0-9]{3,}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Candidate",
        "Verified",
        "Deprecated",
        "Archived"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "source_patterns": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^PAT-[0-9]{3,}$"
      }
    },
    "source_cases": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^CASE-[0-9]{3}$"
      }
    },
    "health": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "health_state": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "x-repository": {
    "status": "schema_candidate",
    "model_impact": "repository_only_not_production",
    "boundary": "Experience entities have no Runtime, Decision, Prediction, Strategy, Scoring, or trading authority."
  }
}
