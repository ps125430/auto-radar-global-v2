{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-radar.local/schemas/playbook/playbook.schema.json",
  "title": "Playbook Repository Entity",
  "description": "Repository-only schema for static Playbook knowledge templates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "playbook_id",
    "version",
    "status",
    "title",
    "description",
    "graph_reference",
    "lifecycle_state",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "playbook_id": {
      "type": "string",
      "pattern": "^PB-[0-9]{3,}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Candidate",
        "Shadow",
        "Verified",
        "Deprecated",
        "Archived"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "graph_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "relation",
        "target"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "pattern": "^(CASE|PAT|EXP|PB|RULE|EV)-[0-9]{3,}$"
        },
        "relation": {
          "type": "string",
          "enum": [
            "DERIVED_FROM",
            "REFERENCES",
            "GENERATES",
            "USES",
            "DEPENDS_ON",
            "RELATED_TO"
          ]
        },
        "target": {
          "type": "string",
          "pattern": "^(CASE|PAT|EXP|PB|RULE|EV)-[0-9]{3,}$"
        }
      }
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "Draft",
        "Candidate",
        "Shadow",
        "Verified",
        "Deprecated",
        "Archived"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "x-repository": {
    "status": "schema_candidate",
    "model_impact": "repository_only_not_production",
    "boundary": "Playbooks are static knowledge templates with no Runtime, Decision, Strategy, or Production Rule authority."
  }
}

