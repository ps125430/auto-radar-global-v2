{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-radar.local/schemas/outcome/outcome.schema.json",
  "title": "Outcome Repository Entity",
  "description": "Repository-only record of observed post-prediction market windows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "outcome_id",
    "prediction_ref",
    "decision_ref",
    "market_open",
    "market_close",
    "window_10m",
    "window_24h",
    "window_t5d",
    "status",
    "model_impact"
  ],
  "properties": {
    "outcome_id": {
      "type": "string",
      "pattern": "^OUT-[0-9]{3,}$"
    },
    "prediction_ref": {
      "type": "string",
      "pattern": "^PRED-[A-Za-z0-9._-]+$"
    },
    "decision_ref": {
      "type": "string",
      "pattern": "^DEC-[A-Za-z0-9._-]+$"
    },
    "market_open": {
      "type": "string"
    },
    "market_close": {
      "type": "string"
    },
    "window_10m": {
      "type": "object"
    },
    "window_24h": {
      "type": "object"
    },
    "window_t5d": {
      "type": "object"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "tracking",
        "reviewed",
        "archived"
      ]
    },
    "model_impact": {
      "type": "string",
      "const": "review_only_not_production"
    }
  },
  "x-repository": {
    "status": "schema_candidate",
    "model_impact": "review_only_not_production",
    "boundary": "Outcome records are repository review inputs only."
  }
}
