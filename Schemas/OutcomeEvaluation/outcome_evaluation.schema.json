{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-radar.local/schemas/outcome-evaluation/outcome_evaluation.schema.json",
  "title": "Outcome Evaluation Repository Entity",
  "description": "Repository-only evaluation record linked to one Outcome.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evaluation_id",
    "prediction_ref",
    "outcome_ref",
    "overall_pms",
    "narrative_match",
    "leader_match",
    "theme_match",
    "flow_match",
    "timing_match",
    "risk_match",
    "luck_penalty",
    "evaluation_status",
    "status",
    "model_impact"
  ],
  "properties": {
    "evaluation_id": {
      "type": "string",
      "pattern": "^EVAL-[0-9]{3,}$"
    },
    "prediction_ref": {
      "type": "string",
      "pattern": "^PRED-[A-Za-z0-9._-]+$"
    },
    "outcome_ref": {
      "type": "string",
      "pattern": "^OUT-[0-9]{3,}$"
    },
    "overall_pms": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "narrative_match": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "leader_match": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "theme_match": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "flow_match": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "timing_match": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "risk_match": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "luck_penalty": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "evaluation_status": {
      "type": "string",
      "enum": [
        "TRUE_ALPHA",
        "PARTIAL_SUCCESS",
        "TIMING_MISMATCH",
        "NARRATIVE_DRIFT",
        "LEADER_DRIFT",
        "COMPLETE_MISS",
        "BLACK_SWAN"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "archived"
      ]
    },
    "model_impact": {
      "type": "string",
      "const": "research_only_not_production"
    }
  },
  "x-repository": {
    "status": "schema_candidate",
    "model_impact": "research_only_not_production",
    "boundary": "PMS and match values are review metrics only and are not production scoring."
  }
}
