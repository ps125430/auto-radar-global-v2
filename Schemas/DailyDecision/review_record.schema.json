{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-radar.local/schemas/daily-decision/review_record.schema.json",
  "title": "Daily Review Repository Entity",
  "description": "Repository-only review record linked to Prediction, Outcome, and Evaluation references.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "prediction_ref",
    "outcome_ref",
    "evaluation_ref",
    "prediction_error",
    "behavior_error",
    "execution_error",
    "missing_information",
    "preventable",
    "learning_target",
    "status",
    "model_impact"
  ],
  "properties": {
    "review_id": {
      "type": "string",
      "pattern": "^REV-[0-9]{3,}$"
    },
    "prediction_ref": {
      "type": "string",
      "pattern": "^PRED-[A-Za-z0-9._-]+$"
    },
    "outcome_ref": {
      "type": "string",
      "pattern": "^OUT-[0-9]{3,}$"
    },
    "evaluation_ref": {
      "type": "string",
      "pattern": "^EVAL-[0-9]{3,}$"
    },
    "prediction_error": {
      "type": "object"
    },
    "behavior_error": {
      "type": "object"
    },
    "execution_error": {
      "type": "object"
    },
    "missing_information": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preventable": {
      "type": "object"
    },
    "learning_target": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "archived"
      ]
    },
    "model_impact": {
      "type": "string",
      "const": "review_pipeline_only"
    }
  },
  "x-repository": {
    "status": "schema_candidate",
    "model_impact": "review_pipeline_only",
    "boundary": "Review records are static repository inputs and do not execute Learning logic."
  }
}
