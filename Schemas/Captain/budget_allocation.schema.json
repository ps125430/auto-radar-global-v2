{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-radar.local/schemas/captain/budget_allocation.schema.json",
  "title": "Shadow Budget Allocation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "allocation_id",
    "profile_ref",
    "ship_state_ref",
    "budget",
    "deploy_budget",
    "reserve_budget",
    "suggested_position_count",
    "risk_budget",
    "calculation_basis",
    "selects_securities",
    "order_generation",
    "status",
    "model_impact"
  ],
  "properties": {
    "allocation_id": {"type": "string", "minLength": 1},
    "profile_ref": {"type": "string", "minLength": 1},
    "ship_state_ref": {"type": "string", "minLength": 1},
    "budget": {"type": "number", "minimum": 0},
    "deploy_budget": {"type": "number", "minimum": 0},
    "reserve_budget": {"type": "number", "minimum": 0},
    "suggested_position_count": {"type": "integer", "minimum": 0},
    "risk_budget": {"type": "number", "minimum": 0},
    "calculation_basis": {"type": "object"},
    "selects_securities": {"const": false},
    "order_generation": {"const": false},
    "status": {"const": "shadow_budget_candidate"},
    "model_impact": {"const": "capital_boundary_only_not_production"}
  }
}
