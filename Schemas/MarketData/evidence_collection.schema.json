{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-radar.local/schemas/market-data/evidence_collection.schema.json",
  "title": "Runtime Provider Evidence Collection",
  "type": "object",
  "required": [
    "collection_id",
    "snapshot_ref",
    "generated_at",
    "status",
    "evidence_count",
    "evidence",
    "manual_entry",
    "repository_write_authorized",
    "production_authorized"
  ],
  "properties": {
    "collection_id": {
      "type": "string"
    },
    "snapshot_ref": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "const": "shadow_evidence_collection"
    },
    "evidence_count": {
      "type": "integer",
      "minimum": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "source",
          "timestamp",
          "category",
          "importance",
          "reliability",
          "reference"
        ]
      }
    },
    "manual_entry": {
      "const": false
    },
    "repository_write_authorized": {
      "const": false
    },
    "production_authorized": {
      "const": false
    }
  },
  "x-runtime": {
    "status": "schema_candidate",
    "evidence_candidate_only": true,
    "repository_auto_write": false,
    "production_authorized": false
  }
}
