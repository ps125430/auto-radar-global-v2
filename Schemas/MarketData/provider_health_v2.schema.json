{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-radar.local/schemas/provider_health_v2.schema.json",
  "title": "Real Ocean Provider Health",
  "type": "object",
  "required": [
    "snapshot_version",
    "snapshot_hash",
    "last_update",
    "overall_status",
    "sources",
    "status",
    "repository_write_authorized",
    "production_authorized"
  ],
  "properties": {
    "snapshot_version": {"type": "string"},
    "snapshot_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "last_update": {"type": "string", "format": "date-time"},
    "overall_status": {
      "enum": ["healthy", "degraded", "unavailable"]
    },
    "sources": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "health_status",
          "last_update",
          "latency_ms",
          "source_mode"
        ]
      }
    },
    "status": {"const": "shadow_provider_health"},
    "repository_write_authorized": {"const": false},
    "production_authorized": {"const": false}
  }
}
