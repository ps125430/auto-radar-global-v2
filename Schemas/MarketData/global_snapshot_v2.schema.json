{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-radar.local/schemas/global_snapshot_v2.schema.json",
  "title": "Global Market Snapshot v2",
  "type": "object",
  "required": ["document_id", "snapshot_version", "generated_at", "global", "status", "model_impact", "runtime_network_access", "production_authorized", "repository_write_authorized"],
  "properties": {
    "document_id": {"type": "string", "minLength": 1},
    "snapshot_version": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-(AM|PM)$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "global": {
      "type": "object",
      "required": ["us", "taiwan", "macro", "sector", "theme", "evidence", "market_health"],
      "properties": {
        "us": {"type": "object"},
        "taiwan": {"type": "object"},
        "macro": {"type": "object"},
        "sector": {"type": "array", "minItems": 1},
        "theme": {"type": "array", "minItems": 1},
        "evidence": {"type": "array", "items": {"$ref": "normalized_evidence.schema.json"}},
        "market_health": {"type": "object"}
      },
      "additionalProperties": false
    },
    "status": {"const": "validated_shadow_snapshot_v2"},
    "model_impact": {"const": "provider_data_only_not_production"},
    "runtime_network_access": {"const": false},
    "production_authorized": {"const": false},
    "repository_write_authorized": {"const": false}
  },
  "additionalProperties": false
}
